#!/bin/bash
#         -g 514x20+427+671 \
# Get battery percentage (Linux)
bat() {
	getbat=$(acpi -b | awk -F', ' '{print $2}' | tr -d '%')
	echo "${getbat}%"
}
# Get date
getdate() {
	datetime=$(date +"%Y.%m.%d")
	echo "$datetime"
}
# Get time
gettime() {
	getclock=$(date +"%H:%M")
	echo "$getclock"
}
# Get CPU temperature (Linux)
temp() {
	# Works if lm-sensors is installed and CPU temp available
	coretemp=$(sensors | grep -m1 'Package id 0:' | awk '{print $4}' | tr -d '+°C')
	echo "${coretemp}°C"
}
# Get memory usage (Linux)
mem() {
	memused=$(free -m | awk '/Mem:/ {print $3}')
	echo "${memused}MB"
}
# Get volume (assumes amixer)
vol() {
	vol=$(amixer get Master | awk -F'[][]' 'END{ print $2 }')
	echo "$vol"
}

# Infinite loop for lemonbar
while true; do
	echo -e "%{F#000000}%{B#F0EEDD}%{l}\ue01c $(temp)  \ue040 $(bat)  \ue015 $(gettime)  :::::::::::::::::::::::::::  $(getdate)"
	sleep 1
done |
	lemonbar -d \
		-B "#F0EEDD" \
		-F "#000000" \
		-g 514x20+445+750
